<UserControl x:Class="HermesInstaller.Steps.CheckStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="环境检测" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Text="正在检查你的电脑是否满足安装要求..." FontSize="13"
                   Foreground="#666666" Margin="0,0,0,24"/>

        <!-- 检测项列表 -->
        <ItemsControl x:Name="CheckItems" Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Icon}" FontSize="14" Grid.Column="0"
                                       Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Label}" FontSize="13" Grid.Column="1"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Status}" FontSize="13" Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding StatusColor}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 进度条 -->
        <ProgressBar x:Name="CheckProgress" Height="4" IsIndeterminate="True"
                     Foreground="#6C63FF" Background="#E8E8E8" Margin="0,0,0,16"/>

        <TextBlock x:Name="ResultText" FontSize="12" Foreground="#999999" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
