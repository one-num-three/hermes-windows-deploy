<UserControl x:Class="HermesInstaller.Steps.InstallStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="正在安装 Hermes Agent" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock x:Name="CurrentStepLabel" Text="准备中..." FontSize="13"
                   Foreground="#666666" Margin="0,0,0,16"/>

        <!-- 进度条 -->
        <ProgressBar x:Name="InstallProgress" Height="6" Minimum="0" Maximum="100"
                     Value="0" Foreground="#6C63FF" Background="#E8E8E8" Margin="0,0,0,16"/>

        <!-- 步骤列表 -->
        <ItemsControl x:Name="StepList" Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Icon}" FontSize="12" Width="24"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Label}" FontSize="12"
                                   Foreground="{Binding Color}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 日志输出 -->
        <ScrollViewer x:Name="LogScroller" MaxHeight="120" Visibility="Collapsed">
            <TextBox x:Name="LogOutput" IsReadOnly="True" FontFamily="Consolas"
                     FontSize="11" Background="#1E1E1E" Foreground="#D4D4D4"
                     BorderThickness="0" TextWrapping="Wrap"/>
        </ScrollViewer>

        <!-- 展开日志按钮 -->
        <Button x:Name="ToggleLogButton" Content="▼ 展开日志" Click="ToggleLog_Click"
                Style="{StaticResource LinkButton}" Visibility="Collapsed"
                HorizontalAlignment="Left" FontSize="11" Foreground="#888"/>
    </StackPanel>
</UserControl>
