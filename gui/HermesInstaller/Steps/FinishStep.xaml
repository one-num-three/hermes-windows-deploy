<UserControl x:Class="HermesInstaller.Steps.FinishStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="🎉" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
        <TextBlock Text="安装完成！" FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="Hermes Agent 已成功部署到你的 Windows 上"
                   FontSize="13" Foreground="#666666"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>

        <Border Background="#F0F4FF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="快速开始：" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="1." FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="打开浏览器访问 ">
                        <Run Text="http://localhost:8648" FontFamily="Consolas"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="2." FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="首次使用请配置 AI 模型（设置 → 模型管理）"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="3." FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="桌面已创建快捷方式，下次直接双击即可"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <CheckBox x:Name="LaunchCheck" Content="完成后自动打开 Hermes Web UI" IsChecked="True"
                  Margin="0,0,0,8"/>
        <CheckBox x:Name="ReadmeCheck" Content="打开使用说明" IsChecked="True"/>
    </StackPanel>
</UserControl>
